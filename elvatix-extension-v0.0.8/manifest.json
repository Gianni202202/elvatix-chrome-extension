{
    "name": "Elvatix",
    "description": "Elevate interactions with a human touch in seconds. Your LinkedIn co-pilot boosting conversions.",
    "version": "0.0.8",
    "manifest_version": 3,
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "tabs",
        "cookies"
    ],
    "host_permissions": [
        "https://www.linkedin.com/",
        "https://elvatix.com/*",
        "https://app.elvatix.com/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; frame-src https://elvatix.com https://app.elvatix.com;"
    },
    "action": {
        "default_icon": {
            "128": "/images/elvatix-webapp-icon-256.png"
        },
        "default_popup": "popup.html"
    },
    "icons": {
        "128": "/images/elvatix-webapp-icon-256.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "images/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "externally_connectable": {
        "matches": []
    }
}

